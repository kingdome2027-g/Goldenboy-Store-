# Google Sheets Configuration
# Leave these commented out to use the in-memory data store
# SHEET_ID=your-sheet-id
# GOOGLE_SERVICE_ACCOUNT_KEY_PATH=/path/to/service-account-key.json

# Email Notifications
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=smtp-user
# SMTP_PASS=smtp-password
# EMAIL_FROM="Golden Store <noreply@example.com>"

# API Configuration
# NEXT_PUBLIC_API_URL=http://localhost:3000 (for development)

# Security
# SESSION_SECRET=your-session-secret-key (generated at random for production)
